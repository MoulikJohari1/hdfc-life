# Server
PORT=3000

# SMTP (fill in real values)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Horizon <noreply@horizon.com>"

# Optional: also write a copy to data/outbox for debugging (true/false)
SMTP_SAVE_OUTBOX=true

# Consent email scheduler (every 5 minutes)
CONSENT_EMAIL_CRON_ENABLED=true
CONSENT_EMAIL_INTERVAL_MS=300000
